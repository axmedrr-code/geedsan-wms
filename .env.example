EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# WhatsApp (optional)
WHATSAPP_API_URL=
