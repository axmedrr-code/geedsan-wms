# NUWACO WMS - Docker Environment Configuration
# Copy this file to .env and update values

# Database
DB_PASSWORD=GeedSan@Secure2024

# JWT Secrets (CHANGE THESE IN PRODUCTION!)
JWT_SECRET=geedsan-jwt-secret-change-this-in-production-2024
JWT_REFRESH_SECRET=geedsan-refresh-secret-change-this-in-production-2024

# URLs
NEXT_PUBLIC_API_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

# ChirpStack (update with your ChirpStack details)
CHIRPSTACK_URL=http://your-chirpstack-server:8080
CHIRPSTACK_API_KEY=your-chirpstack-api-key
